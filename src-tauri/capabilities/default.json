{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default"
  ],
  "commands": {
    "allow": [
      "translate_text",
      "save_translation",
      "load_saved_texts",
      "play_tts"
    ]
  }
}
