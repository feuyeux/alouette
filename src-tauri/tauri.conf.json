{
  "productName": "Alouette",
  "version": "0.1.0",
  "identifier": "com.alouette.app",
  "build": {
    "beforeDevCommand": "vite --port 1423 --strictPort",
    "beforeBuildCommand": "npm run vite:build",
    "devUrl": "http://localhost:1423",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Alouette - AI Translation & Text-to-Speech",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}